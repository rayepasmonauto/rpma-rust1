{
  "disable_ai": false,
  "languages": {
    "Rust": {
      "language_servers": ["rust-analyzer"],
    },
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "buildScripts": {
            "enable": true,
          },
          "features": "all",
        },
        "procMacro": {
          "enable": true,
        },
        "checkOnSave": {
          "command": "check",
          "extraArgs": ["--all-targets"],
        },
        "diagnostics": {
          "enable": true,
        },
      },
    },
  },
}
